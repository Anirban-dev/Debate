# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=

# APP_URL: The base domain URL for your application (e.g., http://localhost:3000)
# Used for OAuth redirect callbacks and application links.
APP_URL=http://localhost:3000

# MONGODB_URI: MongoDB connection string for persistent database storage
MONGODB_URI=

# GOOGLE_CLIENT_ID: OAuth Client ID for Google Authentication
GOOGLE_CLIENT_ID=

# GOOGLE_CLIENT_SECRET: OAuth Client Secret for Google Authentication
GOOGLE_CLIENT_SECRET=

# DISCORD_CLIENT_ID: OAuth Client ID for Discord Authentication
DISCORD_CLIENT_ID=

# DISCORD_CLIENT_SECRET: OAuth Client Secret for Discord Authentication
DISCORD_CLIENT_SECRET=

# AUTH_SECRET / NEXTAUTH_SECRET: Encryption secret for NextAuth session tokens
AUTH_SECRET=
NEXTAUTH_SECRET=
