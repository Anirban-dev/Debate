# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
APP_URL=http://localhost:3000

# OAUTH_BASE_URL: (Optional) Force base URL for OAuth callbacks if using http://localhost:3000
OAUTH_BASE_URL=http://localhost:3000

# MONGODB_URI: MongoDB connection string for persistent database storage
MONGODB_URI=

# GOOGLE_CLIENT_ID: OAuth Client ID for Google Authentication
GOOGLE_CLIENT_ID=

# GOOGLE_CLIENT_SECRET: OAuth Client Secret for Google Authentication
GOOGLE_CLIENT_SECRET=

# DISCORD_CLIENT_ID: OAuth Client ID for Discord Authentication
DISCORD_CLIENT_ID=

# DISCORD_CLIENT_SECRET: OAuth Client Secret for Discord Authentication
DISCORD_CLIENT_SECRET=

# JWT_SECRET: Secret key for signing Access Tokens (short-lived JWTs)
JWT_SECRET=

# JWT_REFRESH_SECRET: Secret key for signing Refresh Tokens (long-lived JWTs)
JWT_REFRESH_SECRET=
